# ============================================================
# MissQuiz Telegram Bot - MongoDB Edition
# ============================================================

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here

# Pyrogram / MTProto (for advanced features)
API_ID=38954535
API_HASH=61e5d12278e22ee60507a861fc58b494

# ── Bot Owner ────────────────────────────────────────────────
OWNER_ID=8403136097
# Optional extra authorized user:
# WIFU_ID=

# ── MongoDB ──────────────────────────────────────────────────
# Local:
MONGODB_URL=mongodb://localhost:27017
# Atlas:
# MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=quiz_bot

# ── Flask Session ────────────────────────────────────────────
SESSION_SECRET=your_random_secret_here

# ── Deployment ───────────────────────────────────────────────
MODE=polling
PORT=5000
# WEBHOOK_URL=https://your-domain.com
# RENDER_URL=

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
